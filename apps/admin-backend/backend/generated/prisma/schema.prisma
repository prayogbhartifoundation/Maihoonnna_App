// Prisma schema for Admin Panel backend
// Points to shared Supabase PostgreSQL database

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User Model (subset for admin) ───────────────────────────────────────────
model User {
  id    String   @id
  name  String?
  phone String   @unique
  role  UserRole @default(subscriber)

  @@map("users")
}

enum UserRole {
  subscriber
  beneficiary
  care_companion
  field_manager
  operations_manager
  emergency_coordinator
  volunteer
}

// ─── Zone Model ───────────────────────────────────────────────────────────────
model Zone {
  id             String    @id @default(uuid())
  name           String
  city           String
  address        String
  state          String
  pincode        String
  latitude       Float?
  longitude      Float?
  phone          String?
  leaseStartDate DateTime?
  leaseEndDate   DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  fieldManagerId String?

  @@map("zones")
}

// ─── Callbacks ───────────────────────────────────────────────────────────────

enum CallbackStatus {
  pending
  called
  resolved
}

model CallbackRequest {
  id            String         @id @default(uuid())
  name          String
  phone         String
  subscriberId  String?
  beneficiaryId String?
  status        CallbackStatus @default(pending)
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("callback_requests")
}
