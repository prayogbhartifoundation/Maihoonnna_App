model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  type      String // SECURITY, PROFILE, SUBSCRIPTION
  action    String // PASSWORD_CHANGED, PROFILE_UPDATED, PLAN_RENEWED
  details   Json?
  status    String   @default("success") // success, failure
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("activity_logs")
}

model Hobby {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hobbies")
}

model ServiceRequest {
  id                String       @id @default(uuid())
  beneficiaryId     String
  subscriberId      String?      // Nullable: requested directly by beneficiary
  benefitId         String       // The benefit being requested
  preferredDate     DateTime
  preferredTiming   String
  additionalNote    String?
  isRead            Boolean      @default(false)
  requestedByUserId String?
  requestedByRole   String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  beneficiary       Beneficiary  @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  subscriber        User?        @relation("SubscriberServiceRequests", fields: [subscriberId], references: [id])
  requestedByUser   User?        @relation("RequestedByServiceRequests", fields: [requestedByUserId], references: [id])
  benefit           Benefit      @relation(fields: [benefitId], references: [id])

  @@map("service_requests")
}

model Region {
  id             String                      @id @default(uuid())
  name           String                      @unique
  city           String
  state          String
  latitude       Float
  longitude      Float
  radiusKm       Float                       @default(30.0)
  isActive       Boolean                     @default(true)
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  zones          Zone[]
  packageRegions SubscriptionPackageRegion[]

  @@map("regions")
}

model SubscriptionPackageRegion {
  packageId String
  regionId  String
  package   SubscriptionPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  region    Region              @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@id([packageId, regionId])
  @@map("subscription_package_regions")
}

// ─── Sathi Network Volunteer Table ───────────────────────────────────────────

model Volunteer {
  id                 String              @id @default(uuid())
  phone              String              @unique
  email              String?             @unique
  password           String?
  name               String
  age                Int?
  gender             String?
  profilePhoto       String?
  fcmToken           String?
  refreshToken       String?
  applicationStatus  VolunteerStatus     @default(SUBMITTED)
  previousExperience String?
  whyJoin            String?
  address            String?
  interests          String[]            @default([])
  totalCreditHours   Float               @default(0)   // accumulated hours volunteered
  totalCreditPoints  Float               @default(0)   // credit points earned
  monthlyGoalHours   Float               @default(10)
  verifiedAt         DateTime?
  verifiedById       String?             // admin User.id who approved
  rejectionReason    String?
  rejectedAt         DateTime?
  lastLoginAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  assignments        VolunteerAssignment[]
  visitLogs          VolunteerVisitLog[]
  creditTransactions VolunteerCreditTransaction[]
  sathiVisitRequests SathiVisitRequest[]

  @@map("volunteers")
}

// ─── Many-to-Many: Volunteer ↔ Beneficiary ──────────────────────────────────

model VolunteerAssignment {
  id            String           @id @default(uuid())
  volunteerId   String           // FK -> Volunteer.id
  beneficiaryId String           // FK -> Beneficiary.id
  assignedById  String?          // admin User.id who created this assignment
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  volunteer     Volunteer        @relation(fields: [volunteerId], references: [id])
  beneficiary   Beneficiary      @relation(fields: [beneficiaryId], references: [id])
  visitLogs     VolunteerVisitLog[]

  @@unique([volunteerId, beneficiaryId])
  @@map("volunteer_assignments")
}

// ─── Visit Log: the deduction + credit event ────────────────────────────────

model VolunteerVisitLog {
  id                           String              @id @default(uuid())
  volunteerId                  String              // FK -> Volunteer.id
  beneficiaryId                String              // FK -> Beneficiary.id
  assignmentId                 String              // FK -> VolunteerAssignment.id
  subscriptionId               String?             // which subscription was charged
  subscriptionBenefitBalanceId String?           // which benefit balance was deducted
  checkInTime                  DateTime
  checkOutTime                 DateTime?
  minutesLogged                Float?              // computed at checkout
  hoursEarned                  Float?              // minutesLogged / 60
  creditPointsEarned           Float?              // hoursEarned × conversion rate
  beneficiaryBalanceBefore     Float?              // snapshot for audit
  beneficiaryBalanceAfter      Float?              // snapshot for audit
  notes                        String?
  status                       VolunteerVisitStatus @default(in_progress)
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
  volunteer                    Volunteer           @relation(fields: [volunteerId], references: [id])
  beneficiary                  Beneficiary         @relation(fields: [beneficiaryId], references: [id])
  assignment                   VolunteerAssignment @relation(fields: [assignmentId], references: [id])

  @@map("volunteer_visit_logs")
}

// ─── Credit Ledger: full audit trail ────────────────────────────────────────

model VolunteerCreditTransaction {
  id          String              @id @default(uuid())
  volunteerId String              // FK -> Volunteer.id
  visitLogId  String?             @unique
  type        CreditTransactionType
  minutesDelta  Float             // +ve = earned, -ve = redeemed
  pointsDelta   Float             // +ve = earned, -ve = redeemed
  balanceAfter  Float             // running balance snapshot
  description String?
  createdAt   DateTime            @default(now())
  volunteer   Volunteer           @relation(fields: [volunteerId], references: [id])

  @@map("volunteer_credit_transactions")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum VolunteerStatus {
  NOT_APPLIED
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum VolunteerVisitStatus {
  in_progress
  completed
  cancelled
}

enum CreditTransactionType {
  earned       // from a completed visit
  redeemed     // volunteer spent points
  adjustment   // manual admin correction
  expiry       // points expired
}

model SathiVisitRequest {
  id              String               @id @default(uuid())
  beneficiaryId   String
  volunteerId     String?              // The volunteer who accepted it (null if pending)
  dateTime        DateTime
  reason          String
  status          SathiRequestStatus   @default(PENDING) // PENDING, ACCEPTED, REJECTED
  rejectionReason String?
  rejectedBy      String[]             @default([]) // Array of volunteer IDs who rejected this request
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  beneficiary     Beneficiary          @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  volunteer       Volunteer?           @relation(fields: [volunteerId], references: [id], onDelete: SetNull)

  @@map("sathi_visit_requests")
}

enum SathiRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}



