model VitalDefinition {
  id          String  @id @default(uuid())
  code        String  @unique
  name        String
  description String?
  unit        String?
  dataType    String // 'numeric', 'dual_numeric', 'text', 'boolean'
  inputMin    Float?
  inputMax    Float?
  normalMin   Float?
  normalMax   Float?

  // ── Dual Numeric fields (e.g. Blood Pressure: Systolic/Diastolic) ──
  value1Label String? // e.g. "Systolic"
  value2Label String? // e.g. "Diastolic"
  normalMin2  Float? // Normal min for second value
  normalMax2  Float? // Normal max for second value

  // ── Text type fields ──
  textOptions  String[] @default([]) // Predefined options e.g. ["Happy","Sad","Anxious"]
  alertOptions String[] @default([]) // Options that trigger an alert e.g. ["Sad","Anxious"]

  // ── Boolean type fields ──
  booleanTrueLabel  String? // Custom label for "Yes" (default: "Yes")
  booleanFalseLabel String? // Custom label for "No" (default: "No")
  booleanAlertValue Boolean? // Which boolean value triggers alert (true=Yes, false=No, null=none)

  isSystemVital Boolean  @default(true)
  displayOrder  Int      @default(0)
  iconCode      String?
  isActive      Boolean  @default(true)
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdBy          User?                    @relation("VitalDefinitionCreator", fields: [createdById], references: [id])
  templateItems      VitalTemplateItem[]
  beneficiaryConfigs BeneficiaryVitalConfig[]
  readings           VitalReading[]

  @@map("vital_definitions")
}

model VitalConfigTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy      User?                    @relation("VitalConfigTemplateCreator", fields: [createdById], references: [id])
  items          VitalTemplateItem[]
  appliedConfigs BeneficiaryVitalConfig[]

  @@map("vital_config_templates")
}

model VitalTemplateItem {
  id                String   @id @default(uuid())
  templateId        String
  vitalDefinitionId String
  isMandatory       Boolean  @default(false)
  frequency         String? // 'every_visit', 'weekly', 'monthly'
  displayOrder      Int      @default(0)
  alertOnAbnormal   Boolean  @default(true)
  createdAt         DateTime @default(now())

  template        VitalConfigTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  vitalDefinition VitalDefinition     @relation(fields: [vitalDefinitionId], references: [id])

  @@unique([templateId, vitalDefinitionId])
  @@map("vital_template_items")
}

model BeneficiaryVitalConfig {
  id                String  @id @default(uuid())
  beneficiaryId     String
  vitalDefinitionId String
  templateId        String?
  isActive          Boolean @default(true)
  isMandatory       Boolean @default(false)
  frequency         String  @default("every_visit")
  alertOnAbnormal   Boolean @default(true)

  customNormalMin Float?
  customNormalMax Float?

  effectiveFrom DateTime  @default(now()) @db.Date
  effectiveTo   DateTime? @db.Date
  notes         String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  beneficiary     Beneficiary          @relation(fields: [beneficiaryId], references: [id])
  vitalDefinition VitalDefinition      @relation(fields: [vitalDefinitionId], references: [id])
  template        VitalConfigTemplate? @relation(fields: [templateId], references: [id])
  createdBy       User?                @relation("BeneficiaryVitalConfigCreator", fields: [createdById], references: [id])
  updatedBy       User?                @relation("BeneficiaryVitalConfigUpdater", fields: [updatedById], references: [id])
  readings        VitalReading[]

  @@unique([beneficiaryId, vitalDefinitionId, effectiveFrom])
  @@map("beneficiary_vital_configs")
}

model VitalReading {
  id                String  @id @default(uuid())
  beneficiaryId     String
  vitalDefinitionId String
  encounterId       String?
  configId          String?

  valueNumeric  Float?
  valueNumeric2 Float?
  valueText     String?

  unit             String?
  isAbnormal       Boolean?
  abnormalityNotes String?

  capturedById  String
  capturedAt    DateTime @default(now())
  captureMethod String   @default("manual") // 'manual', 'device', 'auto'
  deviceId      String?

  latitude  Float?
  longitude Float?

  createdAt DateTime @default(now())

  beneficiary     Beneficiary             @relation(fields: [beneficiaryId], references: [id])
  vitalDefinition VitalDefinition         @relation(fields: [vitalDefinitionId], references: [id])
  encounter       Visit?                  @relation(fields: [encounterId], references: [id])
  config          BeneficiaryVitalConfig? @relation(fields: [configId], references: [id])
  capturedBy      User                    @relation("VitalReadingCapturedBy", fields: [capturedById], references: [id])
  alerts          VitalAlert[]

  @@index([beneficiaryId, capturedAt(sort: Desc)])
  @@index([encounterId])
  @@index([vitalDefinitionId, capturedAt(sort: Desc)])
  @@map("vital_readings")
}

model VitalAlert {
  id               String    @id @default(uuid())
