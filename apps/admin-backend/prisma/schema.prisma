model VitalDefinition {
  id                 String  @id @default(uuid())
  // ── Versioning ──
  // 'code' is the stable identifier shared across all versions of the same vital (e.g. "blood_pressure")
  // Each admin edit creates a NEW row with incremented version instead of overwriting.
  // CC app always fetches WHERE code = ? AND isLatestVersion = true.
  // Old VitalReadings keep their vitalDefinitionId pointing to the version row at the time of capture.
  code               String
  version            Int     @default(1)
  parentDefinitionId String? // null for v1; points to the id of v1 for all subsequent versions
  isLatestVersion    Boolean @default(true) // only ONE row per code has true at any time

  name        String
  description String?
  category    String? // e.g. "Cardiovascular", "Metabolic", "Neurological" — for grouping in UI
  unit        String?
  dataType    String // 'numeric', 'dual_numeric', 'text', 'boolean'
  inputMin    Float?
  inputMax    Float?
  normalMin   Float?
  normalMax   Float?

  // ── Dual Numeric fields (e.g. Blood Pressure: Systolic/Diastolic) ──
  value1Label String? // e.g. "Systolic"
  value2Label String? // e.g. "Diastolic"
  normalMin2  Float? // Normal min for second value
  normalMax2  Float? // Normal max for second value

  // ── Text type fields ──
  textOptions  String[] @default([]) // Predefined options e.g. ["Happy","Sad","Anxious"]
  alertOptions String[] @default([]) // Options that trigger an alert e.g. ["Sad","Anxious"]

  // ── Boolean type fields ──
  booleanTrueLabel  String? // Custom label for "Yes" (default: "Yes")
  booleanFalseLabel String? // Custom label for "No" (default: "No")
  booleanAlertValue Boolean? // Which boolean value triggers alert (true=Yes, false=No, null=none)

  isSystemVital Boolean  @default(false)
  displayOrder  Int      @default(0)
  iconCode      String?
  isActive      Boolean  @default(true)
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdBy          User?                    @relation("VitalDefinitionCreator", fields: [createdById], references: [id])
  parentDefinition   VitalDefinition?         @relation("VitalVersionChain", fields: [parentDefinitionId], references: [id])
  childVersions      VitalDefinition[]        @relation("VitalVersionChain")
  templateItems      VitalTemplateItem[]
  beneficiaryConfigs BeneficiaryVitalConfig[]
  readings           VitalReading[]

  @@unique([code, version])
  @@index([code, isLatestVersion])
  @@index([isActive])
  @@map("vital_definitions")
}

model VitalConfigTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy      User?                    @relation("VitalConfigTemplateCreator", fields: [createdById], references: [id])
