generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                             String                   @id @default(uuid())
  phone                          String                   @unique
  name                           String?
  email                          String?                  @unique
  password                       String?
  age                            Int?
  dateOfBirth                    DateTime?
  role                           UserRole                 @default(subscriber)
  location                       String?
  latitude                       Float?
  longitude                      Float?
  flatPlot                       String?
  streetArea                     String?
  landmark                       String?
  city                           String?
  state                          String?
  pincode                        String?
  profilePhoto                   String?
  fcmToken                       String?
  isActive                       Boolean                  @default(true)
  isVerified                     Boolean                  @default(false)
  refreshToken                   String?
  lastLoginAt                    DateTime?
  createdAt                      DateTime                 @default(now())
  updatedAt                      DateTime                 @updatedAt
  bookedAppointments             Appointment[]            @relation("AppointmentBookedBy")
  subscriberBeneficiaries        Beneficiary[]            @relation("SubscriberBeneficiaries")
  beneficiaryProfile             Beneficiary?             @relation("BeneficiaryUser")
  assignedCallbackRequests       CallbackRequest[]        @relation("CallbackAssignedTo")
  subscriberCallbackRequests     CallbackRequest[]        @relation("SubscriberCallbacks")
  careCompanionProfile           CareCompanion?           @relation("CareCompanionToUser")
  couponAttemptLogs              CouponAttemptLog[]
  couponUsages                   CouponUsage[]
  emergencyRequestsAssigned      EmergencyRequest[]       @relation("AssignedTo")
  emergencyRequestsRequested     EmergencyRequest[]       @relation("RequestedBy")
  fieldManagersReporting         FieldManager[]           @relation("FieldManagerReportsTo")
  fieldManagerProfile            FieldManager?            @relation("FieldManagerToUser")
  assignedMarketingLeads         MarketingLead[]          @relation("LeadAssignedTo")
  convertedMarketingLeads        MarketingLead[]          @relation("LeadConvertedUser")
  uploadedMedicalRecords         MedicalRecord[]          @relation("MedicalRecordUploadedBy")
  medicationAdherenceRecords     MedicationAdherence[]    @relation("MedicationRecordedBy")
  notifications                  Notification[]
  operationsManagerProfile       OperationsManager?       @relation("OperationsManagerToUser")
  subscriberPayments             Payment[]                @relation("SubscriberPayments")
  backgroundChecksReviewed       StaffBackgroundCheck[]   @relation("BackgroundCheckReviewedBy")
  verifiedStaffDocuments         StaffDocument[]          @relation("StaffDocumentVerifiedBy")
  staffProfilesReporting         StaffProfile[]           @relation("StaffProfileReportsTo")
  staffProfile                   StaffProfile?            @relation("StaffProfileToUser")
  customerServiceProfile         CustomerServiceAgent?    @relation("CSAToUser")
  trainingsAssigned              StaffTraining[]          @relation("TrainingAssignedBy")
  subscriberSubscriptions        Subscription[]           @relation("SubscriberSubscriptions")
  selectedVitalConfigs           BeneficiaryVitalConfig[] @relation("SubscriberVitalSelections")
  zonesAsFieldManager            Zone[]                   @relation("ZoneFieldManager")
  zonesAsOperationsManager       Zone[]                   @relation("ZoneOperationsManager")
  createdVitalDefinitions        VitalDefinition[]        @relation("VitalDefinitionCreator")
  createdVitalTemplates          VitalConfigTemplate[]    @relation("VitalConfigTemplateCreator")
  createdBeneficiaryVitalConfigs BeneficiaryVitalConfig[] @relation("BeneficiaryVitalConfigCreator")
  updatedBeneficiaryVitalConfigs BeneficiaryVitalConfig[] @relation("BeneficiaryVitalConfigUpdater")
  capturedVitalReadings          VitalReading[]           @relation("VitalReadingCapturedBy")
  acknowledgedVitalAlerts        VitalAlert[]             @relation("VitalAlertAcknowledgedBy")
  activityLogs                   ActivityLog[]
  addresses                      Address[]
  serviceRequests                ServiceRequest[]         @relation("SubscriberServiceRequests")
  requestedServiceRequests       ServiceRequest[]         @relation("RequestedByServiceRequests")

  @@index([name])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

model Otp {
  id        String   @id @default(uuid())
  phone     String   @unique
  code      String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("otps")
}

model MedicalCondition {
  id                    String                 @id @default(uuid())
  name                  String                 @unique
  slug                  String                 @unique
  category              String
  icdCode               String?
  description           String?
  icon                  String?
  isCommon              Boolean                @default(false)
  isActive              Boolean                @default(true)
  sortOrder             Int                    @default(0)
  beneficiaryConditions BeneficiaryCondition[]

  @@map("medical_conditions")
}

model BeneficiaryCondition {
  id            String            @id @default(uuid())
  beneficiaryId String
  conditionId   String
  severity      ConditionSeverity @default(moderate)
  diagnosedAt   DateTime?
  diagnosedBy   String?
  notes         String?
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  beneficiary   Beneficiary       @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  condition     MedicalCondition  @relation(fields: [conditionId], references: [id])

  @@unique([beneficiaryId, conditionId])
  @@map("beneficiary_conditions")
}

model MedicalRecord {
  id              String       @id @default(uuid())
  beneficiaryId   String
  uploadedBy      String
  recordType      RecordType   @default(prescription)
  title           String
  fileUrl         String?
  thumbnailUrl    String?
  mimeType        String?
  fileSizeBytes   Int?
  doctorName      String?
  doctorPhone     String?
  doctorSpecialty String?
  hospitalName    String?
  hospitalAddress String?
  recordDate      DateTime?
  expiryDate      DateTime?
  notes           String?
  tags            String[]     @default([])
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  beneficiary     Beneficiary  @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  uploadedByUser  User         @relation("MedicalRecordUploadedBy", fields: [uploadedBy], references: [id])
  medications     Medication[]

  @@map("medical_records")
}

model Medication {
  id                 String                @id @default(uuid())
  beneficiaryId      String
  medicalRecordId    String?
  name               String
  genericName        String?
  dosage             String
  route              MedicationRoute       @default(oral)
  frequency          MedicationFrequency   @default(twice_daily)
  timeSlots          String[]              @default([])
  instructions       String?
  sideEffects        String?
  prescribedBy       String?
  startDate          DateTime
  endDate            DateTime?
  totalDays          Int?
  refillReminderDays Int?
  setReminders       Boolean               @default(false)
  isActive           Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  adherenceRecords   MedicationAdherence[]
  beneficiary        Beneficiary           @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  medicalRecord      MedicalRecord?        @relation(fields: [medicalRecordId], references: [id])

  @@map("medications")
}

model EmergencyContact {
  id                String      @id @default(uuid())
  beneficiaryId     String
  name              String
  phone             String
  alternatePhone    String?
  email             String?
  relationship      String
  address           String?
  isPrimary         Boolean     @default(false)
  isVerified        Boolean     @default(false)
  notifyOnVisit     Boolean     @default(false)
  notifyOnEmergency Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  beneficiary       Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)

  @@map("emergency_contacts")
}

model SchedulePreference {
  id                 String      @id @default(uuid())
  beneficiaryId      String      @unique
  preferredDays      String[]    @default([])
  avoidDays          String[]    @default([])
  preferredSlot      String
  preferredTimeFrom  String?
  preferredTimeTo    String?
  preferFemaleCc     Boolean     @default(false)
  languagePreference String?
  specialNotes       String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  beneficiary        Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)

  @@map("schedule_preferences")
}

model Beneficiary {
  id                    String     @id @default(uuid())
  userId                String     @unique
  subscriberId          String
  name                  String
  photo                 String?
  dateOfBirth           DateTime?
  age                   Int
  gender                GenderType @default(prefer_not_to_say)
  bloodGroup            BloodGroup @default(unknown)
  address               String
  flatPlot              String?
  streetArea            String?
  landmark              String?
  city                  String?
  state                 String?
  pincode               String?
  latitude              Float?
  longitude             Float?
  relationship          String?
  primaryPhysicianName  String?
  primaryPhysicianPhone String?
  primaryPhysicianSpec  String?
  hobbiesInterests      String[]   @default([])

  primaryCcId         String?
  secondaryCcId       String?
  teamId              String?
  emotionalScore      Float                    @default(8.0)
  medicationScore     Float                    @default(100.0)
  healthScore         Float                    @default(8.0)
  dietaryRestrictions String[]                 @default([])
  allergies           String[]                 @default([])
  mobilityStatus      String?
  cognitiveStatus     String?
  insuranceProvider   String?
  insurancePolicyNo   String?
  isActive            Boolean                  @default(true)
  createdBy           String                   @default("subscriber") // "subscriber" | "csa"
  verificationStatus  String                   @default("verified") // "verified" | "pending"
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  maritalStatus       String?
  appointments        Appointment[]
  team                Team?                    @relation(fields: [teamId], references: [id])
  primaryCC           CareCompanion?           @relation("PrimaryCC", fields: [primaryCcId], references: [id])
  secondaryCC         CareCompanion?           @relation("SecondaryCC", fields: [secondaryCcId], references: [id])
  subscriber          User                     @relation("SubscriberBeneficiaries", fields: [subscriberId], references: [id])
  user                User                     @relation("BeneficiaryUser", fields: [userId], references: [id])
  conditions          BeneficiaryCondition[]
  calls               CallLog[]                @relation("BeneficiaryCalls")
  callbackRequests    CallbackRequest[]
  emergencyContacts   EmergencyContact[]
  emergencyRequests   EmergencyRequest[]
  medicalRecords      MedicalRecord[]
  adherenceRecords    MedicationAdherence[]
  medicationList      Medication[]
  packageHourLogs     PackageHoursLog[]
  payments            Payment[]
  schedulePreference  SchedulePreference?
  subscriptions       Subscription[]
  visits              Visit[]
  vitalConfigs        BeneficiaryVitalConfig[]
  vitalReadings       VitalReading[]
  vitalAlerts         VitalAlert[]
  serviceRequests     ServiceRequest[]
  volunteerAssignments VolunteerAssignment[]
  volunteerVisitLogs   VolunteerVisitLog[]
  sathiVisitRequests   SathiVisitRequest[]

  @@index([name])
  @@index([city])
  @@index([pincode])
  @@index([subscriberId])
  @@index([teamId])
  @@index([primaryCcId])
  @@index([secondaryCcId])
  @@map("beneficiaries")
}

model CareCompanion {
  id                        String                     @id @default(uuid())
  userId                    String                     @unique
  name                      String
  photo                     String?
  bio                       String                     @default("")
  specialization            String[]                   @default([])
  languages                 String[]                   @default([])
  zone                      String
  experience                Int?
  qualifications            String[]                   @default([])
  nursingRegistrationNumber String?
  nursingCouncil            String?
  ccType                    String?                    @default("care_assistant") // nurse | care_assistant
  shiftPreference           ShiftPreference            @default(any)
  maxDailyVisits            Int?
  maxPrimaryBeneficiaries   Int                        @default(5)
  maxSecondaryBeneficiaries Int                        @default(5)
  willingClinicVisits       Boolean                    @default(false)
  hasTwoWheeler             Boolean                    @default(false)
  rating                    Float                      @default(5.0)
  totalVisits               Int                        @default(0)
  isAvailable               Boolean                    @default(true)
  isVerified                Boolean                    @default(false)
  teamId                    String?
  joinedAt                  DateTime?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  appointments              Appointment[]
  primaryFor                Beneficiary[]              @relation("PrimaryCC")
  secondaryFor              Beneficiary[]              @relation("SecondaryCC")
  team                      Team?                      @relation(fields: [teamId], references: [id])
  user                      User                       @relation("CareCompanionToUser", fields: [userId], references: [id])
  blockers                  StaffAvailabilityBlocker[]
  visits                    Visit[]

  @@index([name])
  @@index([teamId])
  @@index([zone])
  @@index([isAvailable])
  @@map("care_companions")
}

model FieldManager {
  id               String    @id @default(uuid())
  userId           String    @unique
  name             String
  photo            String?
  bio              String    @default("")
  zone             String
  phone            String?
  qualification    String?
  experience       Int?
  previousEmployer String?
  maxTeamSize      Int?      @default(15)
  canApproveRoster Boolean   @default(true)
  canOnboardCCs    Boolean   @default(false)
  reportsToUserId  String?
  isAvailable      Boolean   @default(true)
  joinedAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  reportsToUser    User?     @relation("FieldManagerReportsTo", fields: [reportsToUserId], references: [id])
  user             User      @relation("FieldManagerToUser", fields: [userId], references: [id])
  teams            Team[]

  @@index([name])
  @@map("field_managers")
}

model OperationsManager {
  id            String   @id @default(uuid())
  userId        String   @unique
  name          String
  photo         String?
  bio           String   @default("")
  phone         String?
  qualification String?
  experience    Int?
  isAvailable   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation("OperationsManagerToUser", fields: [userId], references: [id])

  @@index([name])
  @@map("operations_managers")
}

model CustomerServiceAgent {
  id            String   @id @default(uuid())
  userId        String   @unique
  name          String
  photo         String?
  bio           String   @default("")
  phone         String?
  qualification String?
  experience    Int?
  isAvailable   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation("CSAToUser", fields: [userId], references: [id])

  @@index([name])
  @@map("customer_service_agents")
}

model StaffProfile {
  id                     String                 @id @default(uuid())
  userId                 String                 @unique
  role                   UserRole
  preferredName          String?
  dateOfBirth            DateTime?
  gender                 GenderType             @default(prefer_not_to_say)
  whatsappPhone          String?
  alternatePhone         String?
  addressLine1           String?
  addressLine2           String?
  city                   String?
  state                  String?
  pincode                String?
  aadhaarNumberEncrypted String?
  panNumberEncrypted     String?
  languages              String[]               @default([])
  specialization         String[]               @default([])
  zoneId                 String?
  teamId                 String?
  reportsToUserId        String?
  employmentStatus       StaffEmploymentStatus  @default(draft)
  joinedAt               DateTime?
  activatedAt            DateTime?
  deactivatedAt          DateTime?
  notes                  String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  bgvVerified            Boolean                @default(false)
  kycVerified            Boolean                @default(false)
  bgvAgency              String?
  bgvType                String?
  backgroundChecks       StaffBackgroundCheck[]
  documents              StaffDocument[]
  reportsToUser          User?                  @relation("StaffProfileReportsTo", fields: [reportsToUserId], references: [id])
  team                   Team?                  @relation(fields: [teamId], references: [id])
  user                   User                   @relation("StaffProfileToUser", fields: [userId], references: [id])
  zone                   Zone?                  @relation(fields: [zoneId], references: [id])
  trainings              StaffTraining[]

  @@index([role])
  @@index([employmentStatus])
  @@index([zoneId])
  @@index([teamId])
  @@map("staff_profiles")
}

model StaffDocument {
  id             String            @id @default(uuid())
  staffProfileId String
  documentType   StaffDocumentType
  fileName       String?
  fileKey        String?
  fileUrl        String?
  mimeType       String?
  fileSizeBytes  Int?
  isRequired     Boolean           @default(false)
  isVerified     Boolean           @default(false)
  verifiedAt     DateTime?
  verifiedBy     String?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  staffProfile   StaffProfile      @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  verifiedByUser User?             @relation("StaffDocumentVerifiedBy", fields: [verifiedBy], references: [id])

  @@unique([staffProfileId, documentType])
  @@map("staff_documents")
}

model StaffBackgroundCheck {
  id                  String                @id @default(uuid())
  staffProfileId      String
  backgroundCheckType BackgroundCheckType
  status              BackgroundCheckStatus @default(pending)
  agency              String?
  referenceNumber     String?
  initiatedAt         DateTime?
  completedAt         DateTime?
  validUntil          DateTime?
  reportUrl           String?
  reviewedBy          String?
  notes               String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  reviewedByUser      User?                 @relation("BackgroundCheckReviewedBy", fields: [reviewedBy], references: [id])
  staffProfile        StaffProfile          @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("staff_background_checks")
}

model StaffTraining {
  id             String              @id @default(uuid())
  staffProfileId String
  trainingType   StaffTrainingType
  title          String?
  assignedBy     String?
  dueAt          DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  status         StaffTrainingStatus @default(assigned)
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  assignedByUser User?               @relation("TrainingAssignedBy", fields: [assignedBy], references: [id])
  staffProfile   StaffProfile        @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("staff_trainings")
}

model Team {
  id             String          @id @default(uuid())
  name           String
  fieldManagerId String
  zone           String
  zoneId         String?
  description    String?
  maxCapacity    Int             @default(15)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  careCompanions CareCompanion[]
  staffProfiles  StaffProfile[]
  beneficiaries  Beneficiary[]
  fieldManager   FieldManager    @relation(fields: [fieldManagerId], references: [id])
  zoneRelation   Zone?           @relation(fields: [zoneId], references: [id])

  @@map("teams")
}

model BenefitType {
  id           String    @id @default(uuid())
  code         String?   @unique
  name         String    @unique
  description  String?
  iconCode     String?
  displayOrder Int       @default(0)
  isActive     Boolean   @default(true)
  isSystem     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  benefits     Benefit[]

  @@map("benefit_types")
}

model Benefit {
  id                     String                       @id @default(uuid())
  benefitTypeId          String
  name                   String
  description            String?
  isChargeable           Boolean                      @default(false)
  unitCost               Float?
  currency               String                       @default("INR")
  unitLabel              String?
  defaultUnits           Int                          @default(1)
  isActive               Boolean                      @default(true)
  displayOrder           Int                          @default(0)
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  benefitType            BenefitType                  @relation(fields: [benefitTypeId], references: [id])
  packageBenefits        PackageBenefit[]
  balances               SubscriptionBenefitBalance[]
  visits                 Visit[]
  packageVersionBenefits PackageVersionBenefit[]
  serviceRequests        ServiceRequest[]

  @@map("benefits")
}

model PackageBenefit {
  id               String              @id @default(uuid())
  packageId        String
  benefitId        String
  unitsIncluded    Int                 @default(1)
  unitsPeriod      String              @default("monthly")
  unit             String?
  isUnlimited      Boolean             @default(false)
  allowRollover    Boolean             @default(false)
  maxRolloverUnits Int?
  displayOrder     Int                 @default(0)
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  benefit          Benefit             @relation(fields: [benefitId], references: [id])
  package          SubscriptionPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, benefitId])
  @@map("package_benefits")
}

model PackageDiscount {
  id            String              @id @default(uuid())
  packageId     String
  billingCycle  String
  discountType  String
  discountValue Float
  finalCost     Float?
  isActive      Boolean             @default(true)
  validFrom     DateTime?
  validTo       DateTime?
  createdAt     DateTime            @default(now())
  package       SubscriptionPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, billingCycle])
  @@map("package_discounts")
}

// ─── Package Versioning ───────────────────────────────────────────────────────
// Each time a package is edited, a new PackageVersion is created (old one frozen).
// Subscriptions point to the exact version purchased — never changes after signup.

model PackageVersion {
  id                 String                  @id @default(uuid())
  packageCode        String // Maps to SubscriptionPackage.type e.g. "GOLD"
  version            Int // 1, 2, 3...
  name               String
  tagline            String?
  description        String
  basePrice          Float
  mrp                Float                   @default(0)
  currency           String                  @default("INR")
  billingCycle       String                  @default("monthly")
  durationMonths     Int                     @default(1)
  isFreeTrial        Boolean                 @default(false)
  trialDurationDays  Int?
  visitsPerWeek      Int                     @default(0)
  hoursPerMonth      Float                   @default(0)
  maxBeneficiaries   Int                     @default(1)
  features           String[]                @default([])
  highlightFeatures  String[]                @default([])
  color              String?
  isPopular          Boolean                 @default(false)
  isLatest           Boolean                 @default(true)
  isActive           Boolean                 @default(true)
  sortOrder          Int                     @default(0)
  discountPercentage Float                   @default(0)
  miscellaneousCost  Float                   @default(0)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  versionBenefits    PackageVersionBenefit[]
  subscriptions      Subscription[]
  payments           Payment[]

  @@unique([packageCode, version])
  @@index([packageCode, isLatest])
  @@map("package_versions")
}

model PackageVersionBenefit {
  id                String                       @id @default(uuid())
  packageVersionId  String
  benefitId         String // FK to live Benefit (for deduction lookup)
  snapshotName      String // Snapshot of Benefit.name at version creation
  snapshotUnitLabel String? // Snapshot of Benefit.unitLabel at version creation
  unitsIncluded     Int                          @default(1)
  unitsPeriod       String                       @default("monthly")
  isUnlimited       Boolean                      @default(false)
  displayOrder      Int                          @default(0)
  notes             String?
  createdAt         DateTime                     @default(now())
  packageVersion    PackageVersion               @relation(fields: [packageVersionId], references: [id], onDelete: Cascade)
  benefit           Benefit                      @relation(fields: [benefitId], references: [id])
  benefitBalances   SubscriptionBenefitBalance[]

  @@unique([packageVersionId, benefitId])
  @@map("package_version_benefits")
}

model SubscriptionPackage {
  id                 String            @id @default(uuid())
  type               String            @unique
  name               String
  tagline            String?
  description        String
  basePrice          Float
  currency           String            @default("INR")
  billingCycle       String            @default("monthly")
  isFreeTrial        Boolean           @default(false)
  trialDurationDays  Int?
  activeFrom         DateTime          @default(now())
  activeTo           DateTime?
  discountSixMonths  Float             @default(10.0)
  discountAnnual     Float             @default(20.0)
  durationMonths     Int               @default(1)
  visitsPerWeek      Int               @default(0)
  hoursPerMonth      Float             @default(0)
  maxBeneficiaries   Int               @default(1)
  features           String[]          @default([])
  highlightFeatures  String[]          @default([])
  color              String?
  isPopular          Boolean           @default(false)
  isGlobal           Boolean           @default(true)
  isActive           Boolean           @default(true)
  sortOrder          Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  discountPercentage Float             @default(0)
  mrp                Float             @default(0)
  miscellaneousCost  Float             @default(0)
  packageBenefits    PackageBenefit[]
  packageDiscounts   PackageDiscount[]
  subscriptions      Subscription[]
  packageRegions     SubscriptionPackageRegion[]

  @@map("subscription_packages")
}

model Subscription {
  id               String                       @id @default(uuid())
  subscriberId     String
  beneficiaryId    String? // Nullable: package can be purchased before beneficiary is linked
  packageType      String // Legacy: SubscriptionPackage.type (kept for compat)
  packageVersionId String? // FK → PackageVersion (the exact version purchased)
  duration         SubscriptionDuration         @default(monthly)
  startDate        DateTime
  endDate          DateTime
  renewalDate      DateTime?
  autoRenew        Boolean                      @default(false)
  visitsCompleted  Int                          @default(0)
  visitsTotal      Int
  hoursUsed        Float                        @default(0.0)
  hoursTotal       Float
  isActive         Boolean                      @default(true)
  cancelledAt      DateTime?
  cancellationNote String?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  hoursLogs        PackageHoursLog[]
  payments         Payment[]
  benefitBalances  SubscriptionBenefitBalance[]
  beneficiary      Beneficiary?                 @relation(fields: [beneficiaryId], references: [id])
  package          SubscriptionPackage          @relation(fields: [packageType], references: [type])
  packageVersion   PackageVersion?              @relation(fields: [packageVersionId], references: [id])
