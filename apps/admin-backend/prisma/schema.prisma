  displayOrder      Int      @default(0)
  alertOnAbnormal   Boolean  @default(true)
  createdAt         DateTime @default(now())

  template        VitalConfigTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  vitalDefinition VitalDefinition     @relation(fields: [vitalDefinitionId], references: [id])

  @@unique([templateId, vitalDefinitionId])
  @@map("vital_template_items")
}

model BeneficiaryVitalConfig {
  id                     String  @id @default(uuid())
  beneficiaryId          String
  // vitalDefinitionId stores the ORIGINAL v1 id (code anchor).
  // When admin creates a new version of a vital, existing configs remain linked
  // via the code. Backend resolves latest version at fetch time.
  vitalDefinitionId      String
  templateId             String?
  // Who selected this vital for the beneficiary (subscriber or admin)
  selectedBySubscriberId String?

  isActive        Boolean @default(true)
  isMandatory     Boolean @default(false)
  // 'every_visit' | 'daily' | 'weekly' | 'monthly'
  frequency       String  @default("every_visit")
  alertOnAbnormal Boolean @default(true)

  customNormalMin Float?
  customNormalMax Float?

  startDate DateTime  @default(now())
  endDate   DateTime?
  notes     String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  beneficiary          Beneficiary          @relation(fields: [beneficiaryId], references: [id])
  vitalDefinition      VitalDefinition      @relation(fields: [vitalDefinitionId], references: [id])
  selectedBySubscriber User?                @relation("SubscriberVitalSelections", fields: [selectedBySubscriberId], references: [id])
  template             VitalConfigTemplate? @relation(fields: [templateId], references: [id])
  createdBy            User?                @relation("BeneficiaryVitalConfigCreator", fields: [createdById], references: [id])
  updatedBy            User?                @relation("BeneficiaryVitalConfigUpdater", fields: [updatedById], references: [id])
  readings             VitalReading[]

  @@unique([beneficiaryId, vitalDefinitionId]) // one active config per vital per beneficiary
  @@index([beneficiaryId, isActive])
  @@map("beneficiary_vital_configs")
}

model VitalReading {
  id                String  @id @default(uuid())
  beneficiaryId     String
  // Points to the specific VitalDefinition VERSION row active when this reading was captured.
  // This is the schema version anchor — old readings remain 100% interpretable
  // even if the admin later publishes a newer version of the vital.
  vitalDefinitionId String
  visitId           String? // direct FK to the Visit (encounter) this reading belongs to
  configId          String? // FK to BeneficiaryVitalConfig — the subscriber's selection that triggered this

  // ── Value storage ── only the relevant field(s) are populated based on dataType
  valueNumeric  Float? // 'numeric' dataType  (e.g. Heart Rate = 72)
  valueNumeric2 Float? // 'dual_numeric' dataType second value (e.g. Diastolic = 80)
  valueText     String? // 'text' dataType  (e.g. Mood = "Happy")
  valueBoolean  Boolean? // 'boolean' dataType  (e.g. Medication Taken = true)
  valueJson     Json? // future complex vitals (e.g. Eye Test: {left: 2.3, right: 2.5})

  unit             String?
  isAbnormal       Boolean?
  abnormalityNotes String?

  capturedById  String
  capturedAt    DateTime @default(now())
  captureMethod String   @default("manual") // 'manual', 'device', 'auto'
  source        String   @default("care_companion") // 'care_companion' | 'beneficiary'
  deviceId      String?

  latitude  Float?
  longitude Float?

  createdAt DateTime @default(now())

  beneficiary     Beneficiary             @relation(fields: [beneficiaryId], references: [id])
  vitalDefinition VitalDefinition         @relation(fields: [vitalDefinitionId], references: [id])
  visit           Visit?                  @relation(fields: [visitId], references: [id])
  config          BeneficiaryVitalConfig? @relation(fields: [configId], references: [id])
  capturedBy      User                    @relation("VitalReadingCapturedBy", fields: [capturedById], references: [id])
  alerts          VitalAlert[]

  @@index([beneficiaryId, capturedAt(sort: Desc)])
  @@index([visitId])
  @@index([vitalDefinitionId, capturedAt(sort: Desc)])
  @@map("vital_readings")
}

