# ─── COPY THIS FILE TO .env AND FILL IN YOUR VALUES ──────────────────────────
# cp .env.example .env
#
# HOW TO SWITCH ENVIRONMENTS:
#   LOCAL:      Set EXPO_PUBLIC_ENV=local  (uses localhost:PORT)
#   PRODUCTION: Set EXPO_PUBLIC_ENV=production  (uses EXPO_PUBLIC_PRODUCTION_API_URL)
#
# For physical device testing via ADB (USB):
#   Keep EXPO_PUBLIC_LOCAL_IP=localhost  (ADB reverse handles port forwarding)
#
# For physical device testing over Wi-Fi (no USB):
#   Set EXPO_PUBLIC_LOCAL_IP to your PC's local IP (find with `ipconfig` on Windows)
#   e.g. EXPO_PUBLIC_LOCAL_IP=192.168.1.10

EXPO_PUBLIC_ENV=local
EXPO_PUBLIC_PRODUCTION_API_URL=https://api.maihoonna.com/app-api/
EXPO_PUBLIC_LOCAL_IP=localhost
EXPO_PUBLIC_API_PORT=8001

# ─── THIRD PARTY SERVICES ────────────────────────────────────────────────────
# Get from Google Cloud Console
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# ─── PAYMENT SETTINGS ────────────────────────────────────────────────────────
# Use rzp_test_... for development, rzp_live_... for production
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_YOUR_KEY
