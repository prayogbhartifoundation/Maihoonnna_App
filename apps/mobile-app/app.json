{
  "expo": {
    "name": "maihoonna",
    "slug": "maihoonna",
    "version": "1.0.0",
    "orientation": "portrait",

    "updates": {
      "enabled": false
    },

    "icon": "./assets/images/group1.png",

    "scheme": "maihoonna",
    "userInterfaceStyle": "automatic",

    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "AIzaSyDPrFpN29FZ786mTWjIbeQvW3y6ztjx3xU"
      }
    },

    "android": {
      "package": "com.rajeev_23.maihoonna",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/group2.png",
        "backgroundColor": "#E6F4FE"
      },
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDPrFpN29FZ786mTWjIbeQvW3y6ztjx3xU"
        }
      }
    },

    "web": {
      "favicon": "./assets/images/group3.png"
    },

    "plugins": [
      "expo-router",

      [
        "expo-splash-screen",
        {
          "image": "./assets/images/group4.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],

      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "MaiHoonNa needs your location to show your address on the map and find nearby care services.",
          "locationWhenInUsePermission": "MaiHoonNa needs your location to pin your address and find nearby Care Companions."
        }
      ],

      "expo-image",
      "expo-web-browser",

      [
        "expo-notifications",
        {
          "icon": "./assets/images/group1.png",
          "color": "#FF7A00",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "MaiHoonNa Notifications"
        }
      ]
    ],

    "extra": {
      "eas": {
        "projectId": "5d0036fa-6e0c-47ed-9213-c8ed8ebaee75"
      }
    }
  }
}
