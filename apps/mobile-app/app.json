{
  "expo": {
    "name": "maihoonna",
    "slug": "maihoonna",
    "version": "1.0.0",
    "orientation": "portrait",
    "updates": {
      "enabled": false
    },
    "icon": "./assets/images/icon.png",
    "scheme": "maihoonna",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "AIzaSyDPrFpN29FZ786mTWjIbeQvW3y6ztjx3xU"
      },
      "bundleIdentifier": "com.rajeev-23.maihoonna",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "MaiHoonNa uses your location to share it with your care team when you trigger an SOS Emergency Alert.",
        "NSLocationAlwaysUsageDescription": "MaiHoonNa needs background location access so your GPS coordinates are shared with caregivers the moment you press the SOS button."
      }
    },
    "android": {
      "package": "com.rajeev_23.maihoonna",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDPrFpN29FZ786mTWjIbeQvW3y6ztjx3xU"
        }
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/group4.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "MaiHoonNa needs your location to show your address on the map and find nearby care services.",
          "locationWhenInUsePermission": "MaiHoonNa needs your location to pin your address and find nearby Care Companions."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FF7A00",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "MaiHoonNa Notifications",
          "androidNotificationCategoryOptions": {
            "SOS_EMERGENCY": {
              "actions": [
                {
                  "actionId": "SOS_TRIGGER",
                  "buttonTitle": "🚨 Send Emergency SOS",
                  "isDestructive": true,
                  "isAuthenticationRequired": false,
                  "opensAppToForeground": false
                }
              ]
            }
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "5d0036fa-6e0c-47ed-9213-c8ed8ebaee75"
      }
    }
  }
}
